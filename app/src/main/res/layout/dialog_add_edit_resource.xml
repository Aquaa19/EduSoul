<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilResourceTitleDialog"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Resource Title">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextResourceTitleDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilResourceDescriptionDialog"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Description (Optional)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextResourceDescriptionDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:lines="3"
                android:gravity="top"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilFilePathOrUrlDialog"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="File Path or URL">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextFilePathOrUrlDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resource Type:"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerResourceType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.AppCompat.Spinner.Underlined"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target Audience:"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/checkBoxTargetAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Students (No specific batch/subject)"
            android:checked="true"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/checkBoxTargetSpecificBatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Specific Batch"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textViewTargetBatchLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Batch:"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:visibility="gone"/>

        <Spinner
            android:id="@+id/spinnerTargetBatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            style="@style/Widget.AppCompat.Spinner.Underlined"/>

        <CheckBox
            android:id="@+id/checkBoxTargetSpecificSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Specific Subject"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textViewTargetSubjectLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Subject:"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:visibility="gone"/>

        <Spinner
            android:id="@+id/spinnerTargetSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            style="@style/Widget.AppCompat.Spinner.Underlined"/>

    </LinearLayout>
</ScrollView>