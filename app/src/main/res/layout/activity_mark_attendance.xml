<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for MarkAttendanceActivity:
    Allows a teacher to select a date, then a scheduled class session for that day,
    and mark attendance for the enrolled students.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.teacher.MarkAttendanceActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.EduSoul.AppBarOverlay">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarMarkAttendance"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.EduSoul.PopupOverlay"
            app:title="Mark Attendance" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date:"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"/>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAttendanceDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:hint="Attendance Date">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextAttendanceDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                tools:text="2025-06-05"/>
        </com.google.android.material.textfield.TextInputLayout>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Class Session:"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"/>
        <Spinner
            android:id="@+id/spinnerSelectClassSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            style="@style/Widget.AppCompat.Spinner.Underlined"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewStudentAttendance"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"
            tools:visibility="visible"
            tools:listitem="@layout/item_student_for_attendance" />

        <TextView
            android:id="@+id/textViewNoStudentsInClass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select a date and class session to begin."
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <Button
            android:id="@+id/buttonSubmitAttendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Submit Attendance"
            android:visibility="gone"
            tools:visibility="visible"/>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
