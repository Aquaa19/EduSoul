<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.admin.ManageClassScheduleActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayoutManageSchedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.EduSoul.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarManageSchedule"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.EduSoul.PopupOverlay"
            app:title="Manage Class Schedule" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="8dp">

        <CalendarView
            android:id="@+id/calendarViewSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>
        <!-- Consider theming the CalendarView if needed -->

        <TextView
            android:id="@+id/textViewSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            android:gravity="center_horizontal"
            android:padding="8dp"
            tools:text="Schedule for: 2024-06-05"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewClassSessions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_class_session" />

        <TextView
            android:id="@+id/textViewNoSessions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No sessions scheduled for this date."
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="visible"/>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddClassSession"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add_event"
        app:tint="@android:color/white"
        android:contentDescription="Add New Class Session" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
