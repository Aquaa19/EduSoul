<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.admin.SetWeeklyTimetableActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.EduSoul.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarSetWeeklyTimetable"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.EduSoul.PopupOverlay"
            app:title="Set Weekly Timetable" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Batch to Set Schedule:"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"/>

        <Spinner
            android:id="@+id/spinnerSelectBatchForTimetable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            style="@style/Widget.AppCompat.Spinner.Underlined"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/containerWeeklySchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Monday"
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                            <ImageButton
                                android:id="@+id/buttonAddMonday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Add session for Monday"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewMonday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            tools:listitem="@layout/item_class_session"
                            tools:itemCount="1"/>
                        <TextView
                            android:id="@+id/textViewNoSessionsMonday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sessions scheduled."
                            android:textAlignment="center"
                            android:padding="8dp"
                            android:visibility="gone"
                            tools:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tuesday"
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                            <ImageButton
                                android:id="@+id/buttonAddTuesday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Add session for Tuesday"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewTuesday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            tools:listitem="@layout/item_class_session"
                            tools:itemCount="0"/>
                        <TextView
                            android:id="@+id/textViewNoSessionsTuesday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sessions scheduled."
                            android:textAlignment="center"
                            android:padding="8dp"
                            android:visibility="gone"
                            tools:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Wednesday"
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                            <ImageButton
                                android:id="@+id/buttonAddWednesday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Add session for Wednesday"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewWednesday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:id="@+id/textViewNoSessionsWednesday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sessions scheduled."
                            android:textAlignment="center"
                            android:padding="8dp"
                            android:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Thursday"
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                            <ImageButton
                                android:id="@+id/buttonAddThursday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Add session for Thursday"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewThursday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:id="@+id/textViewNoSessionsThursday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sessions scheduled."
                            android:textAlignment="center"
                            android:padding="8dp"
                            android:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Friday"
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                            <ImageButton
                                android:id="@+id/buttonAddFriday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Add session for Friday"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewFriday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:id="@+id/textViewNoSessionsFriday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sessions scheduled."
                            android:textAlignment="center"
                            android:padding="8dp"
                            android:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Saturday"
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                            <ImageButton
                                android:id="@+id/buttonAddSaturday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Add session for Saturday"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewSaturday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:id="@+id/textViewNoSessionsSaturday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sessions scheduled."
                            android:textAlignment="center"
                            android:padding="8dp"
                            android:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Sunday"
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>
                            <ImageButton
                                android:id="@+id/buttonAddSunday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Add session for Sunday"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewSunday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:id="@+id/textViewNoSessionsSunday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No sessions scheduled."
                            android:textAlignment="center"
                            android:padding="8dp"
                            android:visibility="visible"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center"
        android:elevation="10dp"
        tools:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>