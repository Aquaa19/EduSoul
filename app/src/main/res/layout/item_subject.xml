<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imageViewSubjectIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_subjects"
            app:tint="?attr/colorPrimary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Subject Icon"/>

        <TextView
            android:id="@+id/textViewSubjectName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            tools:text="Mathematics"
            app:layout_constraintStart_toEndOf="@id/imageViewSubjectIcon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/imageButtonManageTopics"/>

        <TextView
            android:id="@+id/textViewSubjectCode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            tools:text="MATH101"
            app:layout_constraintStart_toEndOf="@id/imageViewSubjectIcon"
            app:layout_constraintTop_toBottomOf="@id/textViewSubjectName"
            app:layout_constraintEnd_toStartOf="@id/imageButtonManageTopics"/>

        <TextView
            android:id="@+id/textViewSubjectDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            tools:text="Introduction to advanced calculus and algebra concepts."
            app:layout_constraintStart_toEndOf="@id/imageViewSubjectIcon"
            app:layout_constraintTop_toBottomOf="@id/textViewSubjectCode"
            app:layout_constraintEnd_toStartOf="@id/imageButtonManageTopics"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageButton
            android:id="@+id/imageButtonManageTopics"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_topic_list"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/colorControlNormal"
            app:layout_constraintEnd_toStartOf="@id/imageButtonEditSubject"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Manage Syllabus Topics"/>

        <ImageButton
            android:id="@+id/imageButtonEditSubject"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/colorControlNormal"
            app:layout_constraintEnd_toStartOf="@id/imageButtonDeleteSubject"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Edit Subject"/>

        <ImageButton
            android:id="@+id/imageButtonDeleteSubject"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/design_default_color_error"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Delete Subject"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>