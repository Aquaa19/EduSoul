<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for ViewScheduleActivity:
    Allows a teacher to view their personal class schedule using a CalendarView.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.teacher.ViewScheduleActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.EduSoul.AppBarOverlay">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarViewSchedule"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.EduSoul.PopupOverlay"
            app:title="My Schedule" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="8dp">

        <CalendarView
            android:id="@+id/calendarViewTeacherSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textViewTeacherSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            android:gravity="center_horizontal"
            android:padding="8dp"
            tools:text="Schedule for: Wednesday, June 4, 2025"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewTeacherClassSessions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_class_session" />

        <TextView
            android:id="@+id/textViewNoTeacherSessions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No classes scheduled for this date."
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="visible"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
