<?xml version="1.0" encoding="utf-8"?>
<!--
    Item layout for displaying a single Exam in a RecyclerView.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imageViewExamIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_exam_management"
            app:tint="?attr/colorPrimary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Exam Icon"/>

        <TextView
            android:id="@+id/textViewExamName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            tools:text="Mid-Term Mathematics Test"
            app:layout_constraintStart_toEndOf="@id/imageViewExamIcon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/imageButtonEditExam"/>

        <TextView
            android:id="@+id/textViewExamDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            tools:text="Batch: Grade 10 | Subject: Math"
            app:layout_constraintStart_toEndOf="@id/imageViewExamIcon"
            app:layout_constraintTop_toBottomOf="@id/textViewExamName"
            app:layout_constraintEnd_toStartOf="@id/imageButtonEditExam"/>

        <TextView
            android:id="@+id/textViewExamDateAndMarks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            tools:text="Date: 2025-09-15 | Max Marks: 100"
            app:layout_constraintStart_toEndOf="@id/imageViewExamIcon"
            app:layout_constraintTop_toBottomOf="@id/textViewExamDetails"
            app:layout_constraintEnd_toStartOf="@id/imageButtonEditExam"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageButton
            android:id="@+id/imageButtonEditExam"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/colorControlNormal"
            app:layout_constraintEnd_toStartOf="@id/imageButtonDeleteExam"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Edit Exam"/>

        <ImageButton
            android:id="@+id/imageButtonDeleteExam"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/design_default_color_error"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Delete Exam"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
